  m_text: "<style=\"Naslov\">\u041B\u043E\u0437\u0430 \u041D\u0435\u043C\u0430\u045A\u0438\u045B\u0430</style>\n<br>\n<style=\"Podnaslov\">\u0421\u0442\u0435\u0444\u0430\u043D
    \u041D\u0435\u043C\u0430\u045A\u0430</style>\n\u0420\u043E\u0452\u0435\u043D
    \u0458\u0435 \u0443 \u043C\u0435\u0441\u0442\u0443 \u0420\u0438\u0431\u043D\u0438\u0446\u0438
    \u043A\u0430\u043E \u043D\u0430\u0458\u043C\u043B\u0430\u0452\u0438 \u0441\u0438\u043D
    \u043E\u0446\u0430 \u0417\u0430\u0432\u0438\u0434\u0438\u043D\u0430. \u0411\u0438\u043E
    \u0458\u0435 \u0440\u043E\u0434\u043E\u043D\u0430\u0447\u0435\u043B\u043D\u0438\u043A
    \u0441\u0440\u043F\u0441\u043A\u0435 \u0432\u043B\u0430\u0434\u0430\u0440\u0441\u043A\u0435
    \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0458\u0435 \u041D\u0435\u043C\u0430\u045A\u0438\u045B.
    \u040A\u0435\u0433\u043E\u0432\u0430 \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0430
    \u043E\u0433\u043B\u0435\u0434\u0430 \u0441\u0435 \u043D\u0430\u0458\u0432\u0438\u0448\u0435
    \u0443 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u043A\u043E\u043C \u043E\u0441\u043B\u043E\u0431\u0430\u0452\u0430\u045A\u0443
    \u0421\u0440\u0431\u0438\u0458\u0435 \u043E\u0434 \u0412\u0438\u0437\u0430\u043D\u0442\u0438\u0458\u0441\u043A\u043E\u0433
    \u0446\u0430\u0440\u0441\u0442\u0432\u0430. \u041E\u0441\u0442\u0432\u0430\u0440\u0438\u043E
    \u0458\u0435 \u0443\u0458\u0435\u0434\u0438\u045A\u0435\u045A\u0435 \u0433\u043E\u0442\u043E\u0432\u043E
    \u0441\u0432\u0438\u0445 \u0441\u0440\u043F\u0441\u043A\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0443 \u0458\u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u0443 \u0441\u0440\u043F\u0441\u043A\u0443
    \u0434\u0440\u0436\u0430\u0432\u0443\n<style=\"ImportantContent\">\u0413\u043E\u0434\u0438\u043D\u0435
    \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0435: </style>1166-1196\n<style=\"ImportantContent\">\u0417\u0430\u0434\u0443\u0436\u0431\u0438\u043D\u0435:
    </style>\u0402\u0443\u0440\u0452\u0435\u0432\u0438 \u0421\u0442\u0443\u043F\u043E\u0432\u0438
    (1171), \u041C\u0430\u043D\u0430\u0441\u0442\u0438\u0440 \u0421\u0442\u0443\u0434\u0435\u043D\u0438\u0446\u0430
    (1186), \u041C\u0430\u043D\u0430\u0441\u0442\u0438\u0440 \u0425\u0438\u043B\u0430\u043D\u0434\u0430\u0440
    (1199)\n<page>\n<style=\"Podnaslov\">\u0421\u0442\u0435\u0444\u0430\u043D \u041D\u0435\u043C\u0430\u045A\u0438\u045B
    \u041F\u0440\u0432\u043E\u0432\u0435\u043D\u0447\u0430\u043D\u0438</style>\n\u0421\u0442\u0435\u0444\u0430\u043D
    \u041D\u0435\u043C\u0430\u045A\u0430 II, \u043F\u043E\u0437\u043D\u0430\u0442\u0438\u0458\u0438
    \u043A\u0430\u043E \u041F\u0440\u0432\u043E\u0432\u0435\u043D\u0447\u0430\u043D\u0438,
    \u0434\u043E\u0431\u0438\u043E \u0458\u0435 \u043D\u0430\u0434\u0438\u043C\u0430\u043A
    \u0458\u0435\u0440 \u0458\u0435 \u0431\u0438\u043E \u043F\u0440\u0432\u0438 \u043A\u0440\u0443\u043D\u0438\u0441\u0430\u043D\u0438
    \u043A\u0440\u0430\u0459 \u043C\u0435\u0452\u0443 \u041D\u0435\u043C\u0430\u045A\u0438\u045B\u0438\u043C\u0430
    (1217). \u0417\u0430\u0441\u043B\u0443\u0436\u0430\u043D \u0458\u0435 \u0437\u0430
    \u0458\u0430\u0447\u0430\u045A\u0435 \u0441\u0440\u043F\u0441\u043A\u0435 \u0434\u0440\u0436\u0430\u0432\u0435
    \u0438 \u045A\u0435\u043D\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u045A\u0435
    \u043A\u0430\u043E \u043A\u0440\u0430\u0459\u0435\u0432\u0438\u043D\u0435\n<style=\"ImportantContent\">\u0413\u043E\u0434\u0438\u043D\u0435
    \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0435: </style>1243-1276 <style=\"ImportantContent\">\u0417\u0430\u0434\u0443\u0436\u0431\u0438\u043D\u0435:
    </style>\u0416\u0438\u0447\u0430 (1207), \u041C\u0430\u043D\u0430\u0441\u0442\u0438\u0440
    \u0421\u0432\u0435\u0442\u0435 \u0411\u043E\u0433\u043E\u0440\u043E\u0434\u0438\u0446\u0435
    \u041F\u0440\u0435\u0447\u0438\u0441\u0442\u0435\n<page>\n<style=\"Podnaslov\">\u0421\u0442\u0435\u0444\u0430\u043D
    \u0423\u0440\u043E\u0448 I</style>\n\u0421\u0442\u0435\u0444\u0430\u043D \u0423\u0440\u043E\u0448
    I, \u043F\u043E\u0437\u043D\u0430\u0442\u0438\u0458\u0438 \u043A\u0430\u043E
    \u0423\u0440\u043E\u0448 \u0412\u0435\u043B\u0438\u043A\u0438. \u0423 \u0432\u0440\u0435\u043C\u0435
    \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0435 \u043A\u0440\u0430\u0459\u0430
    \u0423\u0440\u043E\u0448\u0430 I \u043F\u043E\u0441\u0442\u0430\u0432\u0459\u0435\u043D\u0438
    \u0441\u0443 \u0442\u0435\u043C\u0435\u0459\u0438 \u0437\u0430 \u0434\u0430\u0459\u0443
    \u0442\u0435\u0440\u0438\u0442\u043E\u0440\u0438\u0458\u0430\u043B\u043D\u0443
    \u0435\u043A\u0441\u043F\u0430\u043D\u0437\u0438\u0458\u0443 \u0441\u0440\u043F\u0441\u043A\u0435
    \u0434\u0440\u0436\u0430\u0432\u0435. \u041F\u043E\u0434\u0441\u0442\u0430\u043A\u0430\u043E
    \u0458\u0435 \u0440\u0430\u0437\u0432\u043E\u0458 \u0440\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0430
    \u0438 \u0442\u0440\u0433\u043E\u0432\u0438\u043D\u0435, \u0447\u0438\u043C\u0435
    \u0458\u0435 \u0421\u0440\u0431\u0438\u0458\u0430 \u0435\u043A\u043E\u043D\u043E\u043C\u0441\u043A\u0438
    \u043E\u0458\u0430\u0447\u0430\u043B\u0430. \u0411\u0438\u043E \u0458\u0435 \u043F\u043E\u0437\u043D\u0430\u0442
    \u043F\u043E \u0441\u0443\u043A\u043E\u0431\u0438\u043C\u0430 \u0441\u0430 \u041C\u0430\u0452\u0430\u0440\u0441\u043A\u043E\u043C
    \u0438 \u043F\u043E\u043A\u0443\u0448\u0430\u0458\u0438\u043C\u0430 \u0434\u0430
    \u043F\u0440\u043E\u0448\u0438\u0440\u0438 \u0441\u0440\u043F\u0441\u043A\u0435
    \u0442\u0435\u0440\u0438\u0442\u043E\u0440\u0438\u0458\u0435. \u040A\u0435\u0433\u043E\u0432\u0430
    \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0430 \u0441\u0435 \u0441\u043C\u0430\u0442\u0440\u0430
    \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u043C \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0458\u0435
    \u0421\u0440\u0431\u0438\u0458\u0435\n<style=\"ImportantContent\">\u0413\u043E\u0434\u0438\u043D\u0435
    \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0435: </style>1196-1228\n<style=\"ImportantContent\">\u0417\u0430\u0434\u0443\u0436\u0431\u0438\u043D\u0435:
    </style>Co\u043F\u043E\u0446\u0430\u043D\u0438 (1255), \u0426\u0440\u043A\u0432\u0430
    \u0421\u0432\u0435\u0442\u0435 \u0422\u0440\u043E\u0458\u0438\u0446\u0435, \u0422\u043E\u043F\u043B\u0438\u0447\u043A\u0438
    \u043C\u0430\u043D\u0430\u0441\u0442\u0438\u0440, \u041C\u0430\u043D\u0430\u0441\u0442\u0438\u0440
    \u041C\u043E\u0440\u0430\u0432\u0438\u0446\u0430\n<page>\n<style=\"Podnaslov\">\u0414\u0440\u0430\u0433\u0443\u0442\u0438\u043D</style>\n\u041A\u0440\u0430\u0459
    \u0414\u0440\u0430\u0433\u0443\u0442\u0438\u043D \u0431\u0438\u043E \u0458\u0435
    \u043D\u0430\u0458\u0441\u0442\u0430\u0440\u0438\u0458\u0438 \u0441\u0438\u043D
    \u0441\u0440\u043F\u0441\u043A\u043E\u0433 \u043A\u0440\u0430\u0459\u0430 \u0421\u0442\u0435\u0444\u0430\u043D\u0430
    \u0423\u0440\u043E\u0448\u0430 I. \u041D\u0430 \u043F\u0440\u0435\u0441\u0442\u043E
    \u0458\u0435 \u0434\u043E\u0448\u0430\u043E \u043D\u0430\u043A\u043E\u043D \u0448\u0442\u043E
    \u0458\u0435 \u0437\u0431\u0430\u0446\u0438\u043E \u0441\u0432\u043E\u0433 \u043E\u0446\u0430,
    \u0430\u043B\u0438 \u0458\u0435 \u043A\u0430\u0441\u043D\u0438\u0458\u0435 \u0430\u0431\u0434\u0438\u0446\u0438\u0440\u0430\u043E
    \u0443 \u043A\u043E\u0440\u0438\u0441\u0442 \u0431\u0440\u0430\u0442\u0430 \u041C\u0438\u043B\u0443\u0442\u0438\u043D\u0430.
    \u041D\u0430\u043A\u043E\u043D \u0442\u043E\u0433\u0430 \u0458\u0435 \u0443\u043F\u0440\u0430\u0432\u0459\u0430\u043E
    \u0441\u0435\u0432\u0435\u0440\u043D\u0438\u043C \u0434\u0435\u043B\u043E\u0432\u0438\u043C\u0430
    \u0421\u0440\u0431\u0438\u0458\u0435 \u043A\u0430\u043E \u043A\u0440\u0430\u0459
    \u0421\u0440\u0435\u043C\u0430\n<style=\"ImportantContent\">\u0413\u043E\u0434\u0438\u043D\u0435
    \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0435: </style>1276-1282\n<style=\"ImportantContent\">\u0417\u0430\u0434\u0443\u0436\u0431\u0438\u043D\u0435:
    </style>\u0421\u0432\u0435\u0442\u0438 \u0410\u0445\u0438\u043B\u0438\u0458\u0435
    \u0443 \u0410\u0440\u0438\u0459\u0443 (1296)\n<page>\n<style=\"Podnaslov\">\u041C\u0438\u043B\u0443\u0442\u0438\u043D</style>\n\u0421\u0442\u0435\u0444\u0430\u043D
    \u0423\u0440\u043E\u0448 II \u041C\u0438\u043B\u0443\u0442\u0438\u043D \u0431\u0438\u043E
    \u0458\u0435 \u0458\u0435\u0434\u0430\u043D \u043E\u0434 \u043D\u0430\u0458\u043C\u043E\u045B\u043D\u0438\u0458\u0438\u0445
    \u043A\u0440\u0430\u0459\u0435\u0432\u0430 \u0438\u0437 \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0458\u0435
    \u041D\u0435\u043C\u0430\u045A\u0438\u045B\u0430. \u0422\u043E\u043A\u043E\u043C
    \u045A\u0435\u0433\u043E\u0432\u0435 \u0432\u043B\u0430\u0434\u0430\u0432\u0438\u043D\u0435
    \u043E\u0441\u0442\u0432\u0430\u0440\u0435\u043D\u043E \u0458\u0435 \u0437\u043D\u0430\u0447\u0430\u0458\u043D\u043E
    \u043F\u0440\u043E\u0448\u0438\u0440\u0435\u045A\u0435 \u0442\u0435\u0440\u0438\u0442\u043E\u0440\u0438\u0458\u0430
    \u043F\u0440\u0435\u043C\u0430 \u0458\u0443\u0433\u0443. \u0411\u0438\u043E \u0458\u0435
    \u043F\u043E\u0437\u043D\u0430\u0442 \u043F\u043E \u0431\u0440\u043E\u0458\u043D\u0438\u043C
    \u0441\u0443\u043A\u043E\u0431\u0438\u043C\u0430 \u0441\u0430 \u0412\u0438\u0437\u0430\u043D\u0442\u0438\u0458\u043E\u043C,
    \u0430\u043B\u0438 \u0438 \u043F\u043E \u0441\u043A\u043B\u0430\u043F\u0430\u045A\u0443
    \u043C\u0438\u0440\u043E\u0432\u043D\u0438\u0445 \u0443\u0433\u043E\u0432\u043E\u0440\u0430
    \u043A\u0430\u0434\u0430 \u0458\u0435 \u0442\u043E \u0431\u0438\u043B\u043E \u043F\u043E\u0442\u0440\u0435\u0431\u043D\u043E.
    \u041F\u043E\u0434\u0438\u0433\u0430\u043E \u0458\u0435 \u0432\u0435\u043B\u0438\u043A\u0438
    \u0431\u0440\u043E\u0458 \u043C\u0430\u043D\u0430\u0441\u0442\u0438\u0440\u0430,
    \u0437\u0431\u043E\u0433 \u0447\u0435\u0433\u0430 \u0441\u0435 \u0441\u043C\u0430\u0442\u0440\u0430
    \u0458\u0435\u0434\u043D\u0438\u043C \u043E\u0434 \u043D\u0430\u0458\u0432\u0430\u0436\u043D\u0438\u0458\u0438\u0445
